<odoo>
    <data>
        <!-- Add the binary field to the form view of account.move -->
        <record id="view_account_move_form_inherit" model="ir.ui.view">
            <field name="name">account.move.form.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
               <xpath expr="//div[@name='journal_div']" position="after">
                <field name="invoice_upload" readonly="1"/>
                <field name="attachment_upload" widget="many2many_binary" string="Additional Uploads" type="object" readonly="1"/>
                <field name="type_name"  style="font-weight: bold; font-size: 20px;"/>

                </xpath>

            </field>
        </record>
    </data>
</odoo>
