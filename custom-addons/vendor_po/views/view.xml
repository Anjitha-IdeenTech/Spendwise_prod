    <record id="commitment_date_stock_inherited" model="ir.ui.view">
        <field name="name">stock.picking.inherited_new</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//field[@name='origin']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//field[@name='date_done']" position="before">
                <field name="delivery_commitment"/>
                <field name="asm_date"/>
            </xpath>
            <xpath expr="//field[@name='move_ids_without_package']/tree" position="attributes">
                    <attribute name="create">false</attribute>
                <attribute name="delete">false</attribute>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="attributes">
                    <attribute name="readonly">True</attribute>

            </xpath>
            <xpath expr="//field[@name='backorder_id']" position="after">

                <field name="asn_created" options="{'no_edit': True, 'no_create': True ,'no_open': True,'no_quick_create':True}" attrs="{'readonly': [('state', 'in', ('done','cancel'))]}"/>
                <field name="invoice" attrs="{'invisible': [('bill_need', '=', False)]}"/>

                <field name="attachment_upload" widget="many2many_binary" string="Additional Invoice Uploads" type="object"/>
               
                <field name="bill_need" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='product_id']" position="after">

                <field name="suppl_qty" />
            </xpath>
               <xpath expr="//field[@name='product_uom_qty']" position="attributes">
                <attribute name="string">Ordered Quantity</attribute>
            </xpath>
            <xpath expr="//field[@name='quantity_done']" position="attributes">
                <attribute name="string">Received Quantity</attribute>
            </xpath>
<!--            <xpath expr="//field[@name='date_done']" position="before">-->
<!--                <field name="delivery_commitment"/>-->
<!--                <field name="asm_date"/>-->
<!--            </xpath>-->
             <xpath expr="//header/button[@name='action_cancel']" position="after">
                <button name="cancel_balance_stock" string="Cancel Balance Transfer" type="object"
                        class="oe_highlight" groups="product_purchase.group_approvers"
                        attrs="{'invisible': [('state','!=','assigned')]}"/>
            </xpath>



            <div name="button_box" position="inside">
                <button class="oe_stat_button" type="object" name="view_asn"
                    icon="fa-bars" >
                    <div class="o_stat_info">
                             <span class="o_stat_value">
<!--                                <field name="compute_bug_or_damage_count"/>-->
                            </span>
                            <span class="o_stat_text">
                                ASN
                            </span>
                    </div>
                </button>
            </div>
        </field>
    </record>

    <record id="purchase_order_vendor_default_filter_view" model="ir.ui.view">
        <field name="name">purchase.order.list.vendor.default.filter</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
        <field name="arch" type="xml">
           <xpath expr="//search/group" position="inside">
                <!-- Add a default filter for the Vendor -->
                <filter string="Purchase Order" domain="[('state', '=', 'purchase')]"
                        name="vendor_filter"
                        help="This filter shows purchase orders for a specific vendor."/>
            </xpath>
        </field>
    </record>


    <record model="ir.actions.act_window" id="action_view_vendors_po">
        <field name="name">Purchase Order</field>
        <field name="res_model">purchase.order</field>
        <!--            <field name="view_type">form</field>-->
        <field name="view_mode">tree,form</field>
<!--        <field name="domain">[('vendor_user_id','=',uid)]</field>-->
        <field name="domain">[('vendor_user_id','=',uid)]</field>
        <field name="context">{'default_menu_1':True}</field>
        <field name="search_view_id" ref="purchase_order_vendor_default_filter_view"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">Create new PO</p>
        </field>


    </record>

    <record id="view_partner_form" model="ir.ui.view">
            <field name="name">res.partner.form.inherit</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='vat']" position="attributes">
                    <attribute name="string">GST NO</attribute>
                </xpath>
            </field>
    </record>

    <menuitem id="root_vendor_po" name="Vendor PO" groups="vendor_portal.group_vendor_portal_user"  web_icon="vendor_po,static/icons/icon_1.png"/>

    <menuitem id="menu_vendor_po" name="Purchase Orders" parent="root_vendor_po"
              action="action_view_vendors_po"
              sequence="10"/>


