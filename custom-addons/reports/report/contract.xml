<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<odoo>
    <template id="product_contract_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-foreach="docs" t-as="o">


                    <div>
                        <h2 style="text-align: center">
                            PRODUCT CONTRACT
                        </h2>

                    </div>

                    <br/>
                    <br/>

                    <div class="pages">
                        <h3>
                            CONTRACT NO:
                            <span t-field="o.name"/>
                        </h3>
                        <br/>
                        <br/>

                        <div class="row mt32 mb32">
                            <div t-if="o.vendor" class="col-auto" name="div_name">
                                <strong>Vendor:</strong>
                                <p t-field="o.vendor.name"/>
                            </div>

                            <div t-if="o.company_id" class="col-auto" name="div_company">
                                <strong>Company:</strong>
                                <p t-field="o.company_id.name"/>
                            </div>
                            <div t-if="o.user_id" class="col-auto" name="div_user">
                                <strong>User Incharge:</strong>
                                <p t-field="o.user_id.name"/>
                            </div>

                        </div>
                    </div>

                    <br/>
                    <br/>

                    <div class="row mt32 mb32">
                            <div t-if="o.payment_terms" class="col-auto" name="div_payment">
                                <strong>Payment Terms:</strong>
                                <p t-field="o.payment_terms.name"/>
                            </div>

                        <div t-if="o.purchase_tender_type" class="col-auto" name="div_purch_rep">
                                <strong>Contract Type:</strong>
                                <p t-field="o.purchase_tender_type"/>
                            </div>
                        <div t-if="o.status" class="col-auto" name="div_lead_time">
                                <strong>Status:</strong>
                                <p t-field="o.status"/>
                            </div>

                              <div t-if="o.start_date" class="col-auto" name="div_start_date">
                            <strong>Start Date:</strong>
                            <p t-field="o.start_date"/>
                        </div>

                   
                        <div t-if="o.end_date" class="col-auto" name="div_end_date">
                            <strong>End Date:</strong>
                            <p t-field="o.end_date"/>
                        </div>

                        <div t-if="o.status == 'terminate' and o.cancel_date" class="col-auto"
                             name="div_cancel_date">
                            <strong>Termination Date:</strong>
                            <p t-field="o.cancel_date"/>
                        </div>

                    </div>



                    <br/>
                    <br/>

                    <h3>Product Details</h3>

                    <table align="center" style="width:100%; border: 1px solid black;" cellpadding="10">
                        <thead>
                            <tr style="border: 1px solid black;">
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <strong>Product Code</strong>
                                </td>
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <strong>Product</strong>
                                </td>
                                 <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <strong>Description</strong>
                                </td>
<!--                                <td colspan="10" style="padding: 5px; border: 1px solid black;">-->
<!--                                    <strong>Quantity</strong>-->
<!--                                </td>-->
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <strong>Unit Price</strong>
                                </td>
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <strong>UOM</strong>
                                </td>
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <strong>Start Date</strong>
                                </td>
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <strong>End Date</strong>
                                </td>

<!--                                <td colspan="10" style="padding: 5px; border: 1px solid black;">-->
<!--                                    <strong>Total</strong>-->
<!--                                </td>-->

                            </tr>
                        </thead>
                          <t t-foreach="o.product_product_line" t-as="line">
                        <tbody>

                                 <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                <span t-field="line.product_id.default_code"/>
                            </td>

                            <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                <span t-field="line.product_id.name"/>
                            </td>
                                 <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                <span t-field="line.product_id.name"/>
                            </td>

<!--                            <td colspan="10" style="padding: 5px; border: 1px solid black;">-->
<!--                                <span t-field="o.quantity"/>-->
<!--                            </td>-->
                            <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                <span t-field="line.unit_price"/>
                            </td>
                             <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                <span t-field="line.uom"/>
                            </td>
                            <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                <span t-field="o.start_date"/>
                            </td>
                            <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                <span t-field="o.end_date"/>
                            </td>

                            <!--                            </tr>-->

                        </tbody>
                         </t>
                    </table>
                    <h3>Contract - Approvals</h3>

                    <table align="center" style="width:100%; border: 1px solid black;" cellpadding="10">
                        <thead>
                            <tr style="border: 1px solid black;">
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <strong>User</strong>
                                </td>
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <strong>Branch</strong>
                                </td>
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <strong>Department</strong>
                                </td>
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <strong>Status</strong>
                                </td>
                                <!-- <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <strong>De</strong>
                                </td>
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <strong>Payment Terms</strong>
                                </td> -->

                            </tr>
                        </thead>

                        <tbody>
                            <t t-set="lines"
                               t-value="o.request_no.tender_approve_line"/>
                            <tr t-foreach="lines" t-as="move">
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <span t-field="move.user_id.name"/>
                                </td>
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <span t-field="move.branch_id.name"/>
                                </td>
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <span t-field="move.department_id.name"/>
                                </td>
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <span t-field="move.status"/>
                                </td>
                                <!-- <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <span t-field="move.unit_price"/>
                                </td>
                                <td colspan="10" style="padding: 5px; border: 1px solid black;">
                                    <span t-field="move.payment_terms.name"/>
                                </td> -->
                            </tr>
                        </tbody>
                    </table>
                    
                    <div t-if="o.status" class="col-auto" name="div_lead_time">
                                <strong>Terms and Conditions</strong>
                                <p t-field="o.delivery_terms"/>
                            </div>
                </t>
            </t>
        </t>
    </template>
</odoo>