<!--                        <thead>-->
<!--                            <tr style="border: 1px solid black;">-->
<!--                                <td colspan="10" style="padding: 5px; border: 1px solid black;">-->
<!--                                    <strong>User</strong>-->
<!--                                </td>-->
<!--                                <td colspan="10" style="padding: 5px; border: 1px solid black;">-->
<!--                                    <strong>Status</strong>-->
<!--                                </td>-->
<!--                            </tr>-->
<!--                        </thead>-->

<!--                        <tbody>-->
<!--                            <t t-set="need_approval_lines" t-value="bidding.need_approval_line_ids"/>-->
<!--                            <tr t-foreach="need_approval_lines" t-as="need_approval">-->
<!--                                <td colspan="10" style="padding: 5px; border: 1px solid black;">-->
<!--                                    <span t-field="need_approval.user_id.name"/>-->
<!--                                </td>-->
<!--                                <td colspan="10" style="padding: 5px; border: 1px solid black;">-->
<!--                                    <span t-field="need_approval.status"/>-->
<!--                                </td>-->
<!--                            </tr>-->
<!--                        </tbody>-->
<!--                    </table>-->

                </t>
            </t>
        </t>
    </template>
</odoo>



