<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_group_tree">
            <field name="name">Groups</field>
            <field name="model">groups</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="Example Tree">
                    <field name="group_name"/>
                    <field name="budget"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="view_group_form">
            <field name="name">groups.form</field>
            <field name="model">groups</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <h1>
                            <field name="name">Name</field>
                        </h1>
                        <group>
                            <field name="group_name" style="width:25%%"/>
                            <field name="budget" style="width:25%%"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_groups" model="ir.actions.act_window">
            <field name="name">Groups</field>
            <field name="res_model">groups</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first Group!
                </p>
            </field>
        </record>

        <!--        <menuitem id="menu_groups"-->
        <!--                  parent="menu_pr"-->
        <!--                  name="Groups"-->
        <!--                  action="action_groups"-->
        <!--                  groups="product_purchase.group_purchase_admin"-->
        <!--                  sequence="20"-->

        <!--        />-->

        <!--        <menuitem id="menu_groups"-->
        <!--                  name="Groups"-->
        <!--                  action="action_groups"-->
        <!--                  sequence="20"-->

        />


        <record model="ir.ui.view" id="view_product_groups_tree">
            <field name="name">Product Group</field>
            <field name="model">products.group</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree>
                    <field name="sequence"/>
                    <field name="name"/>
                    <field name="company_id"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="view_product_group_form">
            <field name="name">Product Group Form</field>
            <field name="model">products.group</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <h1>
                            <field name="sequence"/>
                        </h1>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                            <group>

                                <field name="company_id"/>
                            </group>
                        </group>


                         <notebook>

                             <page string="Products" name="products_details">
                                <field name="products_line" readonly="0">
                                    <tree editable="bottom">
                                        <field name="product_id"/>
                                        <field name="uom"/>
                                        <field name="quantity"/>
                                        <field name="unit_price"/>


                                    </tree>
                                    <form>
                                       <field name="product_id"/>
                                        <field name="uom"/>

                                    </form>
                                </field>
                            </page>
                         </notebook>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_product_groups" model="ir.actions.act_window">
            <field name="name">Product Groups</field>
            <field name="res_model">products.group</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first Group!
                </p>
            </field>
        </record>

    </data>
</odoo>