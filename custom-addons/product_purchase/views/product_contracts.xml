<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="product_contract_view_search" model="ir.ui.view">
            <field name="model">product.tender.line</field>
            <field name="arch" type="xml">
                <search string="Contracts">
                    <field name="vendor"/>
                    <filter string="Resubmit" name="status_resubmit" domain="[('status', '=', 'resubmit')]"/>
                    <filter string="Expired" name="status_expired" domain="[('status', '=', 'expire')]"/>
                    <filter string="Active" name="status_active" domain="[('status', '=', 'active')]"/>
                    <field string="Expense Category" name="exp_category"/>
                    <group expand="0" string="Group By">
                        <filter string="Expense Category" name="exp_category" context="{'group_by': 'exp_category'}"/>
                    </group>
                </search>
            </field>
        </record>


        <record id="view_product_contracts_tree" model="ir.ui.view">
            <field name="name">product.tender.tree</field>
            <field name="model">product.tender.line</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree create="0" edit="1" delete="0" duplicate="0">

                    <!--                    <field name="product_template_id"/>-->
                    <!--                    <field name="start_date"/>-->
                    <!--                    <field name="end_date"/>-->
                    <!--                    <field name="purchase_tender_type"/>-->

                    <field name="vendor"/>
                    <field name="exp_category"/>
                    <!-- <field name="product_product_line" widget="many2many_tags"/> -->
                    <!--                    <field name="min_qty"/>-->
                    <!--                    <field name="unit_price"/>-->
                    <!--                    <field name="quantity"/>-->
                    <!--                    <field name="total"/>-->
                    <!--                    <field name="purchase_representative"/>-->
                    <!--                    <field name="company_id"/>-->
                    <field name="user_id"/>
                    <field name="status"/>
                    <!--                    <field name="active" widget="boolean_toggle"/>-->
                    <!--                    <field name="delivery_terms"/>-->


                </tree>
            </field>
        </record>

        <record id="view_product_tender_form" model="ir.ui.view">
            <field name="name">product.tender.form</field>
            <field name="model">product.tender.line</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Projects" create="0" edit="1" delete="0" duplicate="0">
                    <header>
                        <button name="action_tender_resubmission"
                                groups="product_purchase.group_buyers"
                                string="Resubmit" class="btn-primary" type="object"
                                attrs="{'invisible': [('status', 'in',( 'resubmit','renew','terminate')),('renew_visible','=',False)]}"
                        />
                        <button name="action_tender_close"
                                string="No renew and Close Pending" class="btn-primary" type="object"
                                groups="product_purchase.group_buyers"
                                attrs="{'invisible': [('status', 'in',( 'resubmit','renew','terminate')),('renew_visible','=',False)]}"
                        />

                        <button name="assign_buyer"
                                string="Assign Rate Contract Renewal"
                                class="btn-primary"
                                type="object"
                                attrs="{'invisible': ['|','|',('status', '!=', 'active'), ('assigned', '=', True),('is_purchase_head', '=', False)]}"/>
                        <button name="button_approve"
                                string="Approve" class="btn-primary" type="object"
                                attrs="{'invisible': ['|' ,('status', '!=', 'resubmit',),('is_an_approver','!=',True)]}"/>

                        <button name="button_terminate"
                                string="Terminate" class="btn-danger" type="object"
                                groups="product_purchase.group_buyers"
                                attrs="{'invisible': [('status', '!=', 'active')]}"/>

                        <field name="status" widget="statusbar" statusbar_visible="active,expire"/>

                    </header>

                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_open_purchase_order" type="object"
                                    class="oe_stat_button" icon="fa-calendar">
                                <!--                                    attrs="{'invisible': [('status','!=','active')]}">-->
                                <span class="o_stat_text">Purchase Order</span>
                            </button>
                            <button name="action_open_contract_request" type="object"
                                    class="oe_stat_button" icon="fa-calendar">
                                <span class="o_stat_text">Contract Request</span>
                            </button>
                            <button name="action_open_purchase_request" type="object"
                                    class="oe_stat_button" icon="fa-calendar">
                                <!--                                    attrs="{'invisible': [('status','!=','active')]}">-->
                                <span class="o_stat_text">Purchase Request(Approved)</span>
                            </button>

                        </div>
                         
                        <div>
                            <h1 style="text-align: center; font-weight: bold;font-size: 28px; ">Contract</h1>
                        </div>
                        <h1>
                            <field name="name" readonly="1"/>

                        </h1>

                        <group>
                            <group col="2">
                                <field name="vendor" readonly="1"/>
                                <!--                                <field name="product_template_id"/>-->
                                <field name="start_date" required="1" readonly="1"/>
                                <field name="end_date" required="1" readonly="1"/>
                                <field name="purchase_tender_type" readonly="1"/>
                                <field name="reason" attrs="{'invisible': [('status', '!=', 'terminate')]}"
                                       readonly="1"/>
                                <field name="cancel_date" attrs="{'invisible': [('status', '!=', 'terminate')]}"
                                       readonly="1"/>
                                <field name="purchase_plan" />
                                <field name="is_purchase_head" invisible="1"/>


                                <field name="assigned" invisible="1"/>
                                <!--                                <field name="min_qty"/>-->
                                <!--                                <field name="unit_price"/>-->
                                <!--                                <field name="quantity"/>-->
                                <!--                                <field name="total"/>-->


                            </group>
                            <group col="2">

                                <!--                                <field name="purchase_representative"/>-->
                                <field name="lead_time" readonly="1"/>
                                <field name="payment_terms" readonly="1"/>

                                <!--                                <field name="company_id"/>-->
                                <field name="user_id" readonly="1"/>
                                <field name="branch_domain" invisible="1" readonly="1"/>
                                <field name="exp_category"/>
                                <field name="company_ids" widget="many2many_tags" readonly="1"/>
                                <field name="branch_ids" widget="many2many_tags" domain="branch_domain" readonly="1"/>
                                <field name="product_group" widget="many2many_tags" readonly="1"/>
                                <field name="active_status" invisible="1"/>
                                <field name="recuring"/>
                                <!--                                <field name="delivery_terms"/>-->
                                 <field name="attachment_vendor_ids" string="Final Vendor Quotation" widget="many2many_binary" readonly="1"/>

                                <field name="is_an_approver" invisible="1"/>

                                <field name="to_approve_users" readonly="0" widget="many2many_tags" invisible="1"/>
                                <field name="approved_users" readonly="0" widget="many2many_tags" invisible="1"/>
                                <field name="next_approve_user" readonly="0" widget="many2many_tags" invisible="1"/>
                                <field name="renew_visible" invisible="1"/>
                                <field name="vendor_addresss" invisible="1"/>
                                <field name="vendor_change_name" invisible="1"/>

                            </group>
                        </group>

                        <notebook>

                            <page string="Products" name="product_details">
                                <field name="product_product_line" readonly="1">
                                    <tree editable="bottom">
                                        <field name="product_id"/>
                                        <field name="uom"/>
                                        <field name="unit_price"/>
                                        <field name="product_group"/>

                                    </tree>
                                    <form>
                                        <field name="product_id"/>
                                        <field name="uom"/>
                                        <field name="unit_price"/>
                                        <field name="product_group"/>
                                    </form>
                                </field>
                            </page>

                            <page string="Value Terms" name="value_terms">
                                <field name="product_quantity_line" readonly="0">
                                    <tree editable="bottom">
                                        <field name="from_date"/>
                                        <field name="to_date"/>
                                        <field name="total_value" sum="Total Value"/>

                                    </tree>
                                    <form>
                                        <field name="from_date"/>
                                        <field name="to_date"/>
                                        <field name="total_value"/>
                                    </form>
                                </field>
                            </page>

                            <page string="Other Info" name="other_terms">
                                <field name="delivery_terms" placeholder="Delivery Terms"/>


                            </page>


                            <page string="Approvals" name="page_approvals">
                                <field name="approve_contract_line_ids" readonly="0">
                                    <tree editable="bottom">
                                        <field name="user_id"/>
                                        <field name="company_id"/>
                                        <field name="location"/>
                                        <field name="department_id"/>
                                        <field name="designation"/>
                                        <field name="approve_order"/>
                                        <field name="contract_approve_ids" invisible="1"/>
                                        <field name="status" readonly="1" store="1" force_save="1"/>
                                    </tree>
                                    <form>
                                        <field name="user_id"/>
                                        <field name="company_id"/>
                                        <field name="location"/>
                                        <field name="department_id"/>
                                        <field name="designation"/>
                                        <field name="approve_order"/>
                                        <field name="status"/>
                                    </form>
                                </field>
                            </page>
                        </notebook>


                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread" options="{'post_refresh': 'recipients'}"/>
                    </div>
                </form>
            </field>
        </record>


        <record id="view_product_contract_search_form" model="ir.ui.view">
            <field name="name">product.tender.line.form</field>
            <field name="model">product.tender.line</field>
            <field name="arch" type="xml">
                <search string="Contracts">
                    <group expand="0" string="Group By">
                        <filter string="Product" name="product" context="{'group_by':'product_template_id'}"/>
                    </group>
                </search>
            </field>
        </record>


        <record model="ir.actions.act_window" id="action_view_product_tenders">
            <field name="name">Rate Contracts</field>
            <field name="res_model">product.tender.line</field>
            <!--            <field name="view_type">form</field>-->
            <field name="view_mode">tree,form</field>
            <field name="domain">[]</field>
            <field name="context">{
                'group_by': 'vendor',
                'search_default_status_resubmit': 1
                }
            </field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create"></p>
            </field>
        </record>


        <!--###################        -->

        <record model="ir.actions.act_window" id="action_view_product_contracts">
            <field name="name">Rate Contracts</field>
            <field name="res_model">product.tender.line</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[]</field>
            <field name="context">{
                'group_by': 'vendor',

                }
            </field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create"></p>
            </field>

        </record>


        <!--        #######################-->


        <!--        <menuitem id="root_product_contracts2" name="Rate Of Contracts" groups="product_purchase.group_purchase_admin"-->
        <!--                  web_icon="product_purchase,static/icons/contract.png" sequence="40"/>-->

        <!--&lt;!&ndash;        <menuitem id="menu_sub_product_contracts1" name="Product Contracts" parent="lease_management.root_product_lease"&ndash;&gt;-->
        <!--&lt;!&ndash;                  action="action_view_product_tenders"&ndash;&gt;-->
        <!--&lt;!&ndash;                  groups="product_purchase.group_purchase_admin,lease_management.group_lease_mangement_user"&ndash;&gt;-->
