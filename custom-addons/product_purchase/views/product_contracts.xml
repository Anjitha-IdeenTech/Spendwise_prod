        <!--&lt;!&ndash;        &ndash;&gt;-->
        <!--        <menuitem id="menu_sub_product_contracts1" name="Product Contracts"-->
        <!--                  action="action_view_product_tenders"-->
        <!--                  sequence="40"/>-->


        <!--  Contract Termination Wizard      -->


        <record id="contract_termination_action" model="ir.ui.view">
            <field name="name">Contract Termination</field>
            <field name="model">contract.terminate.wizard</field>
            <field name="arch" type="xml">


                <form string="Contract Termination">

                    <group>

                        <group col="2">
                            <field name="reason"/>
                            <field name="contract_id" invisible="1"/>

                        </group>
                        <group>
                            <field name="cancel_date"/>
                             <field name="termination_date"/>
                        </group>
                    </group>
                    <footer>
                        <button type="object" name="terminate"
                                string="Terminate" class="btn-primary"/>
                        <button special="cancel" string="Cancel" class="btn-default"/>
                    </footer>
                </form>

            </field>
        </record>


        <record id="termination_action" model="ir.actions.act_window">
            <field name="name">Contract Termination</field>
            <field name="res_model">contract.terminate.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="contract_termination_action"/>
            <field name="target">new</field>
        </record>


        <!--        -->


    </data>
</odoo>