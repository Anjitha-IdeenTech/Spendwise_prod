<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    <record id="view_pr_budget_search" model="ir.ui.view">
            <field name="model">product.request.budget</field>
            <field name="arch" type="xml">
                <search string="Budget">
                    <!--                    <field name="product"/>-->
                    <field name="department_id"/>
                    <field name="exp_category"/>

                    <filter string="HO - IT" name="department_ho_it" domain="[('department_id', '=', 'HO - IT')]"/>

                </search>
            </field>
        </record>
        <record model="ir.ui.view" id="view_pr_budget_tree">
            <field name="name">PR Budget</field>
            <field name="model">product.request.budget</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="Example Tree">
                    <!-- <field name="company_id"/> -->
                    <field name="branch_id"/>
                    <field name="department_id"/>
                    <field name="expense_type"/>
                    <field name="exp_category"/>
                    <field name="from_date"/>
                    <field name="to_date"/>
                    <field name="amount_allowed"/>
                    <field name="amount_used"/>
                    <field name="amount_available"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="view_pr_budget_form">
            <field name="name">product.request.budget.form</field>
            <field name="model">product.request.budget</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_open_purchase_order" type="object"
                                    class="oe_stat_button" icon="fa-calendar">
                                <field name="po" class="o_stat_value"/>
                                <span class="o_stat_text">PO</span>
                            </button>
                        </div>
                        <h1>
                            <field name="name">Name</field>
                        </h1>
                        <group>
                            <group>
                                <field name="company_id"/>
                                <field name="branch_id"/>
                                <field name="department_id"/>
                                <field name="exp_category_domain" invisible="1"/>
                                <field name="expense_type"/>
                                <field name="exp_category"
                                       options='{"always_reload": True, "no_quick_create": True, "no_create_edit": True}'
                                       domain="exp_category_domain"/>
                            </group>
                            <group>
                                <field name="from_date"/>
                                <field name="to_date"/>
                                <field name="amount_allowed"/>
                                <field name="amount_used"/>
                                <field name="amount_available"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread" options="{'post_refresh': 'recipients'}"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="action_pr_budget" model="ir.actions.act_window">
            <field name="name">PR Budget</field>
            <field name="res_model">product.request.budget</field>
            <field name="view_mode">tree,form</field>
            <!--            <field name="domain">[('user_id','=',uid)]</field>-->
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first Budget!
                </p>
            </field>
        </record>
        <!--        <menuitem id="menu_pr_budget"-->
        <!--                  name="PR Budget"-->
        <!--                  parent="menu_create_approve_user"-->
        <!--                  action="action_pr_budget"-->
        <!--        />-->

        <record id="view_budget_graph" model="ir.ui.view">
            <field name="name">purchase.request.graph</field>
            <field name="model">product.request.budget</field>
            <field name="arch" type="xml">
                <graph string="Purchase Budget">
                    <field name="department_id"/>
                    <field name="expense_type"/>
                    <field name="exp_category"/>
                    <field name="from_date"/>
                    <field name="to_date"/>
                    <field name="amount_allowed"/>
                    <field name="amount_used"/>
                    <field name="amount_available"/>


                </graph>
            </field>
        </record>


        <record id="action_product_budget_admin" model="ir.actions.act_window">
            <field name="name">Budget</field>
            <field name="res_model">product.request.budget</field>
            <field name="view_mode">graph,tree,form</field>
            <field name="domain">[]</field>
            <field name="context">{
                'create': False,
                'edit': False,
                }
            </field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                </p>
            </field>
        </record>
    </data>
</odoo>