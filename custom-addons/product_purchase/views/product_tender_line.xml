                <div name="button_box" position="inside">
                    <button class="oe_stat_button" type="object" name="view_contracts"
                            icon="fa-bars">
                        <div class="o_stat_info">
                            <span class="o_stat_value">
                                <field name="contracts_count"/>
                            </span>
                            <span class="o_stat_text">
                                Contracts
                            </span>
                        </div>
                    </button>
                </div>
            </field>
        </record>


        <record id="product_template_fields_inherit" model="ir.ui.view">
            <field name="name">product.template.field.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='detailed_type']" position="before">
                    <field name="brand"/>
                    <field name="oem"/>
                </xpath>

                <xpath expr="//field[@name='uom_po_id']" position="after">
                    <field name="pack_size"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

