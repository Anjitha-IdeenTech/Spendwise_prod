<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="product_user_line_inherit" model="ir.ui.view">
            <field name="name">res.users.lines.inherit</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='preferences']" position="after">
                    <page string="Approve List">
                        <field name="res_user_line_id">
                            <tree editable="bottom">
                                <field name="company_id"  options="{'always_reload': True,'no_edit': True, 'no_create': True ,'no_open': True,'no_quick_create':True}"/>
                                <field name="branch_domain"  invisible="1"/>
                                <field name="branch_id"
                                        options="{'always_reload': True,'no_edit': True, 'no_create': True ,'no_open': True,'no_quick_create':True}"/>
                                <field name="department_id"  options="{'always_reload': True,'no_edit': True, 'no_create': True ,'no_open': True,'no_quick_create':True}"/>
                                <field name="designation"  options="{'always_reload': True,'no_edit': True, 'no_create': True ,'no_open': True,'no_quick_create':True}"/>
                            </tree>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

