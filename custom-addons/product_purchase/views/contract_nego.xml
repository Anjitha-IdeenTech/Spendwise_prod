<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>
        <!-- Tree view for contract.negotiation -->
        <record id="view_contract_negotiation_tree" model="ir.ui.view">
            <field name="name">contract.negotiation.tree</field>
            <field name="model">contract.negotiation</field>
            <field name="arch" type="xml">
                <tree string="Negotiation Comparison Details" create="false">
                    <field name="contract_id"/>
                    <field name="vendor_id"/>
                    <field name="department_id"/>
                    <field name="exp_category_id"/>
                    <field name="initial_price"/>
                    <field name="last_price"/>
                    <field name="price_difference"/>
                    <field name="product_name"/>
                </tree>
            </field>
        </record>
        <record id="view_contract_negotiation_comparison_form" model="ir.ui.view">
            <field name="name">contract.negotiation.comparison.form</field>
            <field name="model">contract.negotiation</field>
            <field name="arch" type="xml">
                <form string="Contract Negotiation Comparison">
                    <sheet>
                        <group>
                            <!-- Fields from contract.negotiation -->
                            <field name="contract_id"/>
                            <field name="vendor_id"/>
                            <field name="department_id"/>
                            <field name="exp_category_id"/>
                            <field name="initial_price"/>
                            <field name="last_price"/>
                            <field name="price_difference"/>
                            <field name="product_name"/>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_contract_negotiation_comparison" model="ir.actions.act_window">
            <field name="name">Contract Negotiation Comparison</field>
            <field name="res_model">contract.negotiation</field>
            <field name="view_mode">form,tree</field>
            <field name="target">current</field>
        </record>
    </data>
</odoo>
