        <record id="update_log_message" model="ir.ui.view">
            <field name="name">RFI</field>
            <field name="model">log.message.wizard</field>
            <field name="arch" type="xml">


                <form string="RFI">

                    <group>

                        <group col="2">

                            <field name="message"/>
                            <field name="user_cc" widget="many2many_tags" options="{'no_edit': True, 'no_create': True ,'no_open': True,'no_quick_create':True}"/>
                            <field name="cc_email"/>
                        </group>
                        <group col="2">
                            <field name="user"/>
                            <field name="to_users" widget="many2many_tags" options="{'no_edit': True, 'no_create': True ,'no_open': True,'no_quick_create':True}"/>
                            <field name="branch_id" widget="many2many_tags" readonly="1"/>
                            <field name="email" readonly="1"/>
                            <!--                            <field name="user_ids" widget="many2many_tags"/>-->
                            <field name="request_id" invisible="1"/>

                        </group>
                    </group>
                    <footer>
                        <button type="object" name="confirm"
                                string="Confirm" class="btn-primary"/>
                        <button special="cancel" string="Cancel" class="btn-default"/>
                    </footer>
                </form>

            </field>
        </record>


