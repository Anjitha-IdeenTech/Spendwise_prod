<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="update_deligate_user_admins_view" model="ir.ui.view">
            <field name="name">Deligate User Admin</field>
            <field name="model">deligate.user.admin.wizard</field>
            <field name="arch" type="xml">
                <form string="Deligate User Details">
                    <group>
                        <group col="2">
                            <field name="user_ids" options='{ "no_quick_create": true, "no_create": true, "no_create_edit": true,"no_open": True,}'/>
                            <field name="deligate_user" options='{ "no_quick_create": true, "no_create": true, "no_create_edit": true,"no_open": True,}'/>
                            <field name="remark" required="1"/>
                            <field name="request_id" invisible="1"/>
                        </group>
                    </group>
                    <footer>
                        <button type="object" name="confirm"
                                string="Confirm" class="btn-primary"/>
                        <button special="cancel" string="Cancel" class="btn-default"/>
                    </footer>
                </form>

            </field>
        </record>


        <record id="update_deligate_user_admin_action" model="ir.actions.act_window">
            <field name="name">Deligate User Admin Details</field>
            <field name="res_model">deligate.user.admin.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="update_deligate_user_admins_view"/>
            <field name="target">new</field>
        </record>


    </data>
</odoo>