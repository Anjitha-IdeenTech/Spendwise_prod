<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_branch_selection_wizard_form" model="ir.ui.view">
            <field name="name">branch.selection.wizard.form</field>
            <field name="model">po.branch.selection.wizard</field>
            <field name="arch" type="xml">
                <form string="Select Branches">
                    <sheet>
                        <group>
                            <field name="branch_ids" widget="many2many_tags"/>
                        </group>
                        <footer>
                            <button string="Confirm" type="object" name="action_confirm_selection" class="btn-primary"/>
                            <button string="Cancel" class="btn-secondary" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
