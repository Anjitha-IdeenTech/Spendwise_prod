<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>


        <record id="add_approver_view" model="ir.ui.view">
            <field name="name">Add Approver</field>
            <field name="model">add.approver.wizard</field>
            <field name="arch" type="xml">


                <form string="Adding User Details">

                    <group>

                        <group col="2">
                            <field name="pr_id" readonly="1" invisible="1"/>
                            <field name="user"  options="{'no_edit': True, 'no_create': True ,'no_open': True,'no_quick_create':True}"/>
                            <field name="branch_id" readonly="1"/>
                            <field name="email" readonly="1"/>
                            <field name="order"/>

                        </group>
                    </group>
                    <footer>
                        <button type="object" name="add_user"
                                string="Confirm" class="btn-primary"/>
                        <button special="cancel" string="Cancel" class="btn-default"/>
                    </footer>
                </form>

            </field>
        </record>


        <record id="add_approver_action" model="ir.actions.act_window">
            <field name="name">CR Deligate User Details</field>
            <field name="res_model">add.approver.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="add_approver_view"/>
            <field name="target">new</field>
        </record>


    </data>
</odoo>