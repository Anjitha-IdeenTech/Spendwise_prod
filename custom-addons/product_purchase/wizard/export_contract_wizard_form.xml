<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>


        <record id="view_export_contract_wizard" model="ir.ui.view">
            <field name="name">export.contract.wizard.form</field>
            <field name="model">export.contract.wizard</field>
            <field name="arch" type="xml">
                <form string="Export Contracts">
                    <group>
                        <field name="filter_by" widget="radio"/>
                        <field name="location_ids" widget="many2many_tags"/>
                        <field name="exp_category_ids" widget="many2many_tags"/>
                    </group>
                    <footer>
                        <button string="Export" type="object" name="action_export" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_export_contract_wizard" model="ir.actions.act_window">
            <field name="name">Export Contracts</field>
            <field name="res_model">export.contract.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_export_contract_wizard"/>
            <field name="target">new</field> <!-- Important for wizards -->
        </record>
    </data>
</odoo>