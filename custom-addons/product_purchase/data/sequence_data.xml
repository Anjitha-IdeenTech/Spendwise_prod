        <record id="seq_contract" model="ir.sequence">
            <field name="name">Contract SQN</field>
            <field name="code">contract</field>
            <field name="prefix">CTR/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_group" model="ir.sequence">
            <field name="name">groups SQN</field>
            <field name="code">groups</field>
            <field name="prefix">GRP/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>