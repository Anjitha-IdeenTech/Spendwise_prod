        <record id="seq_bid_vendor_number_params" model="ir.sequence">
            <field name="name">Bid Vendor Number Sequence</field>
            <field name="code">vendor.bid</field>
            <field name="prefix">BID/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_company_approve_users_number_params" model="ir.sequence">
            <field name="name">Company Approve User Sequence</field>
            <field name="code">pr.company</field>
            <field name="prefix">COMP-APPROVE/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_product_request_budget_params" model="ir.sequence">
            <field name="name">Product Request Budget</field>
            <field name="code">product.request.budget</field>
            <field name="prefix">BUDG/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_vendor_approve_users" model="ir.sequence">
            <field name="name">Vendor Approval</field>
            <field name="code">vendor.approval</field>
            <field name="prefix">VA/</field>
