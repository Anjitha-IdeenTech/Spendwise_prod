<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="product_group_seq" model="ir.sequence">
            <field name="name">Product Group Sequence</field>
            <field name="code">product.group.code</field>
            <field name="prefix">PDG</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>


        <record id="seq_product_request_params" model="ir.sequence">
            <field name="name">Product Request Sequence</field>
            <field name="code">product.request</field>
            <field name="prefix">PR</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_tender_params" model="ir.sequence">
            <field name="name">Purchase Tender Sequence</field>
            <field name="code">product.tender.line</field>
            <field name="prefix">TN</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_tender_request_number_params" model="ir.sequence">
            <field name="name">Tender Request Number Sequence</field>
            <field name="code">tender.request</field>
            <field name="prefix">TRN</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_tender_request_response_number_params" model="ir.sequence">
            <field name="name">Tender Request Response Sequence</field>
            <field name="code">tender.request.response</field>
            <field name="prefix">TRRN</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_tender_item_number_params" model="ir.sequence">
            <field name="name">Tender Item Number Sequence</field>
            <field name="code">tenders</field>
            <field name="prefix">CTR</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_bidding_number_params" model="ir.sequence">
            <field name="name">Bidding Number Sequence</field>
            <field name="code">bidding</field>
            <field name="prefix">BID</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_bid_rfq_number_params" model="ir.sequence">
            <field name="name">Bid Request Number Sequence</field>
            <field name="code">bid.request</field>
            <field name="prefix">BID-RFQ</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
