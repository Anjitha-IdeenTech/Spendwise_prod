<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <data>

        <record id="account_move_inherited_form" model="ir.ui.view">

            <field name="name">account.move.inherited.form</field>

            <field name="model">account.move</field>

            <field name="inherit_id" ref="account.view_move_form"/>

            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_date']" position="after">
                    <field name="lease_id" attrs="{'invisible': [('lease_id', '=', False)]}"/>
                    <field name="from_date" attrs="{'invisible': [('lease_id', '=', False)]}"/>
                    <field name="to_date" attrs="{'invisible': [('lease_id', '=', False)]}"/>

                </xpath>
            </field>
        </record>
    </data>
</odoo>