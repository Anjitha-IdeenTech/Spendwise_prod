        <!-- Tree View Definition -->
        <record id="view_product_lease_po_tree" model="ir.ui.view">
            <field name="name">lease.recurring.po.tree</field>
            <field name="model">lease.recurring.po</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree create="0" edit="1" duplicate="0">
                    <field name="vendor"/>
                    <field name="recurring_lease_id"/>
                    <field name="date"/>
                    <field name="to_date"/>
                    <field name="amount"/>
<!--                    <field name="parent_state" string="Lease State"/>-->
