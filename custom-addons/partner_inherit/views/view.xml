<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record id="inherit_vendor_field" model="ir.ui.view">
        <field name="name">res.vendor.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='msme_file']" position="after">

                <field name="company_types" attrs="{'invisible': [('company_type', '=', 'person')]}"/>

            </xpath>

        </field>
    </record>
</odoo>