<odoo noupdate="1">
<record id="ir_cron_update_bid_status" model="ir.cron">
    <field name="name">Update Bid Request Status</field>
    <field name="model_id" ref="model_bidding"/>
    <field name="state">code</field>
    <field name="code">model._cron_update_bidding_status()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">minutes</field>
    <field name="numbercall">-1</field>
    <field name="doall" eval="False"/>
</record>

    <record id="ir_cron_notify_vendor_bidding" model="ir.cron">
        <field name="name">Notify Vendor Before Bidding Start</field>
        <field name="model_id" ref="model_bid_request"/>
        <field name="state">code</field>
        <field name="code">model._notify_vendor_before_bidding()</field>
        <field name="interval_type">minutes</field>
        <field name="interval_number">1</field>
        <field name="numbercall">30</field>  
        <field name="active">True</field>
    </record>

    </odoo>
